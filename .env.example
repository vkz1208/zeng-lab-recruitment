# AI provider configuration. Keep real keys only in Vercel/production env vars.
AI_PROVIDER=openai
AI_API_STYLE=responses
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_TEXT_MODEL=gpt-5.5
AI_TIMEOUT_MS=90000

# Image generation can use a separate provider/model.
# Default requested image model is image2.
AI_IMAGE_PROVIDER=openai
AI_IMAGE_BASE_URL=https://api.openai.com/v1
AI_IMAGE_API_KEY=
AI_IMAGE_MODEL=image2

# For OpenAI specifically, OPENAI_API_KEY also works if AI_API_KEY is empty.
# OPENAI_API_KEY=
